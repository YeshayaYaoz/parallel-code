{
  "name": "ultrakod-listener",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on router/queue listener for ultrakod — deploys standalone (e.g. to Railway) separately from the Parallel Code desktop app.",
  "type": "module",
  "scripts": {
    "sync-registry": "node scripts/sync-registry.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run sync-registry && tsx src/index.ts",
    "test": "npm run sync-registry && vitest run",
    "typecheck": "npm run sync-registry && tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.210"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
